{
  "name": "@auralis-os/monorepo",
  "private": true,
  "author": {
		"name": "NanoKim",
		"email": "kjyyy7341@gmail.com"
	},
  "type": "module",
  "license": "MIT",
  "scripts": {
		"preinstall": "npx only-allow pnpm",
		"start": "pnpm run demo:start",
		"build": "pnpm -r --sequential build",
		"stage": "pnpm vite-node scripts/stageSite.ts",
		"predeploy": "rimraf dist && pnpm run stage",
		"deploy": "pnpm vite-node scripts/publishSite.ts",
		"pretest": "pnpm --filter @auralis-os/lab... run build",
		"test": "pnpm -r --reporter=append-only test",
		"clean": "rimraf \"./packages/*/dist\" \"./packages/apps/*/dist\" \"./demo/dist\" \"./dist\" --glob",
		"demo:start": "pnpm --filter @auralis-os/demo run start",
		"demo:build": "pnpm --filter @auralis-os/demo run build",
		"demo:preview": "pnpm --filter @auralis-os/demo run preview",
		"demo:stage": "pnpm --filter @auralis-os/demo run stage",
		"demo:fetch": "pnpm --filter @auralis-os/demo run fetch",
		"packages:build": "pnpm -r --sequential --filter \"@auralis-os/demo^...\" build",
		"packages:update": "npx changeset && pnpm changeset version",
		"packages:release": "pnpm changeset publish && pnpm vite-node scripts/createRelease.ts"
	},
 "workspaces": [
		"packages/*",
		"packages/apps/*",
		"demo"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/NanoKim/auralis-os.git"
	},
	"dependencies": {
		"commander": "^12.1.0",
		"expr-eval": "^2.0.2",
		"pnpm": "^9.15.9"
	},
	"devDependencies": {
		"@changesets/cli": "^2.29.8",
		"@auralis-os/lab": "workspace:*",
		"@types/gh-pages": "^6.1.0",
		"@types/node": "^20.19.30",
		"@vitejs/plugin-react": "^4.7.0",
		"rimraf": "^5.0.10",
		"stylelint": "^16.26.1",
		"typescript": "^5.9.3",
		"vite-node": "^6.0.0",
		"vite-plugin-checker": "^0.7.2"
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"auralis-os": "workspace:*",
			"@auralis-os/core": "workspace:*",
      "@auralis-os/velis": "workspace:*",
			"@auralis-os/lab": "workspace:*"
		}
	}
}